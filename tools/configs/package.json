{
    "name": "@kurrent-ui/configs",
    "version": "2.0.0",
    "description": "Configs for the Kurrent Design System",
    "license": "Apache-2.0",
    "prettier": "./prettier",
    "exports": {
        "./eslint": "./eslint.js",
        "./eslint.js": "./eslint.js",
        "./prettier": "./prettier.js",
        "./prettier.js": "./prettier.js",
        "./package.json": "./package.json",
        "./readme.md": "./readme.md"
    },
    "scripts": {
        "build": "echo \"Nothing to do\"",
        "test": "echo \"Nothing to test\"",
        "lint": "echo \"Nothing to lint\"",
        "g:lint": "cd $INIT_CWD && yarn g:eslint && yarn g:prettier",
        "g:fix": "cd $INIT_CWD && yarn g:eslint:fix && yarn g:prettier:fix",
        "g:eslint": "cd $INIT_CWD && eslint \"src/**/*.{ts,tsx}\"",
        "g:eslint:fix": "cd $INIT_CWD && eslint \"src/**/*.{ts,tsx}\" --fix",
        "g:prettier": "cd $INIT_CWD && prettier --check \"src/**/**/!(*.d).{ts,tsx,css,json,html}\"",
        "g:prettier:fix": "cd $INIT_CWD && prettier --write \"src/**/**/!(*.d).{ts,tsx,css,json,html}\""
    },
    "files": [
        "eslint.js",
        "prettier.js"
    ],
    "repository": {
        "type": "git",
        "url": "git@github.com:EventStore/Design-System.git",
        "directory": "tools/configs"
    },
    "dependencies": {
        "@eslint/js": "^10.0.0",
        "typescript-eslint": "^8.63.0"
    },
    "peerDependencies": {
        "eslint": "^10.x",
        "prettier": "^3.x"
    },
    "devDependencies": {
        "eslint": "^10.0.0",
        "prettier": "3.0.0",
        "typescript": "5.1.6"
    }
}
